# Copy this file to .env and fill in your actual values
# cp .env.example .env

# Node.js server port
PORT=5050

# MongoDB connection string (get from MongoDB Atlas or local instance)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.mongodb.net/secureai?appName=Cluster0

# JWT secret — use a long random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# URL of the AI model Flask server (default: localhost)
MODEL_BASE_URL=http://localhost:5001

# Shared secret between the Python model and Node.js /api/alerts/ingest endpoint.
# Must match MODEL_API_KEY env var set on the model process.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MODEL_API_KEY=replace_with_a_random_secret_string

# Camera ID label used when the model doesn't supply one
# MODEL_CAMERA_ID=CAM-AI-01
