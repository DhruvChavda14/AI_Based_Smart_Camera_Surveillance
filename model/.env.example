# model/.env — AI model environment variables
# Copy this to model/.env and fill in your values
# This file is gitignored — never commit it!

# ── Node.js ingest (required for MongoDB image storage) ──────────────────────
NODE_SERVER_URL=http://localhost:5050
MODEL_API_KEY=secureai_model_ingest_key_2026

# ── Email alerts via Gmail SMTP ──────────────────────────────────────────────
# 1. Enable 2-Step Verification on Gmail
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Generate a 16-char App Password (use "Mail" as the app)
SENDER_EMAIL=your_gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAIL=security@yourcompany.com,admin@yourcompany.com

# ── SMS alerts via Twilio (optional) ─────────────────────────────────────────
# Sign up at https://twilio.com — free trial includes a phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SMS_RECIPIENT_NUMBERS=+919876543210,+919123456789
